## RULE 10 — Wire everything into orchestrator.js

FILE: backend/src/scan/orchestrator.js

After writing all new modules, update orchestrator.js to:

1. Import all new modules at the top:
```javascript
const runSqlInjection = require('./modules/sqlInjection');
const runXssReflected = require('./modules/xssReflected');
const runCsrfChecks = require('./modules/csrfChecks');
const runIdorChecks = require('./modules/idorChecks');
const runSensitiveData = require('./modules/sensitiveData');
const runRbacTester = require('./modules/rbacTester');
const runAiEnricher = require('./modules/aiEnricher');
const runAiSummary = require('./modules/aiSummary');
const sendEmailNotification = require('./modules/emailNotifier');
```

2. In the scan execution pipeline, after existing modules run, add in this order:
```javascript
// Update progress and currentModule before each new module
await db.updateScan(scanId, { progress: 40, currentModule: 'SQL Injection Testing' });
await runSqlInjection(scanId, nodes, scan.config, db);

await db.updateScan(scanId, { progress: 50, currentModule: 'XSS Testing' });
await runXssReflected(scanId, nodes, scan.config, db);

await db.updateScan(scanId, { progress: 58, currentModule: 'CSRF Detection' });
await runCsrfChecks(scanId, nodes, scan.config, db);

await db.updateScan(scanId, { progress: 64, currentModule: 'IDOR Testing' });
await runIdorChecks(scanId, nodes, scan.config, db);

await db.updateScan(scanId, { progress: 70, currentModule: 'Sensitive Data Scan' });
await runSensitiveData(scanId, nodes, scan.config, db);

await db.updateScan(scanId, { progress: 76, currentModule: 'RBAC Role Testing' });
await runRbacTester(scanId, nodes, scan.config, db);

await db.updateScan(scanId, { progress: 84, currentModule: 'AI Analysis' });
await runAiEnricher(scanId, scan.config, db);

await db.updateScan(scanId, { progress: 94, currentModule: 'Generating Summary' });
await runAiSummary(scanId, scan.config, db);
```

3. After status is set to "completed":
```javascript
// Recalculate final stats from all findings
const allFindings = await db.getFindingsByScanId(scanId);
const stats = { critical: 0, high: 0, medium: 0, low: 0, info: 0, total: allFindings.length };
for (const f of allFindings) { if (stats[f.severity] !== undefined) stats[f.severity]++; }
await db.updateScan(scanId, { stats: JSON.stringify(stats), status: 'completed', progress: 100, completedAt: new Date().toISOString() });

// Send email notification (non-blocking)
sendEmailNotification(scanId, scan.config, db).catch(e => console.error('Email notification failed:', e));
```

