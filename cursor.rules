## RULE 1 — sqlInjection.js

FILE: backend/src/scan/modules/sqlInjection.js

PURPOSE: Test every URL parameter and discovered form field for SQL injection by sending real payloads and inspecting real HTTP responses.

IMPLEMENTATION RULES:
- Import the nodes array from the current scan (pages and forms discovered by crawler).
- For every node that has query parameters in the URL (e.g. ?id=1&user=admin), extract each parameter.
- Also check sitemapNodes for any "form" type nodes and extract their input fields.
- For each parameter, send 3 separate HTTP GET/POST requests replacing the parameter value with each of these payloads:
  Payload 1: ' OR '1'='1
  Payload 2: 1; DROP TABLE users--
  Payload 3: ' UNION SELECT null,null,null--
- In each response body, search for any of these SQL error signatures (case-insensitive):
  "you have an error in your sql syntax"
  "warning: mysql"
  "unclosed quotation mark"
  "quoted string not properly terminated"
  "pg_query()"
  "sqlite3.operationalerror"
  "ora-01756"
  "microsoft ole db provider for sql server"
  "syntax error" (only if near SQL keywords)
- If any signature matches: create a finding object and save it to the database.
- The finding object must include:
  title: "SQL Injection"
  type: "sqli"
  severity: "critical"
  url: the full URL tested
  method: "GET" or "POST"
  parameter: the name of the vulnerable parameter
  payload: the exact payload string that triggered the error
  evidence: first 500 chars of the response body that contains the error string
  description: "SQL injection vulnerability detected in parameter [name]. The application returned a database error when a crafted SQL payload was injected, indicating the input is not properly sanitised before being used in a SQL query."
- If no SQL error found but response status differs significantly (200 → 500), still create a finding with severity "high" and note "Possible SQL injection — server returned error response to SQL payload."
- Use fetch() with a 8000ms timeout. On network error, skip that node silently.
- Do NOT test parameters named: _token, csrf, authenticity_token, __RequestVerificationToken (these are CSRF tokens, not data params).
- Rate limit: wait 300ms between each request using a sleep helper.
- Export: module.exports = async function runSqlInjection(scanId, nodes, scanConfig, db)

```javascript
// backend/src/scan/modules/sqlInjection.js
const PAYLOADS = [
  "' OR '1'='1",
  "1; DROP TABLE users--",
  "' UNION SELECT null,null,null--"
];

const SQL_ERROR_SIGNATURES = [
  "you have an error in your sql syntax",
  "warning: mysql",
  "unclosed quotation mark",
  "quoted string not properly terminated",
  "pg_query()",
  "sqlite3.operationalerror",
  "ora-01756",
  "microsoft ole db provider for sql server"
];

const SKIP_PARAMS = new Set(["_token","csrf","authenticity_token","__requestverificationtoken"]);

const sleep = ms => new Promise(r => setTimeout(r, ms));

async function testParam(baseUrl, paramName, method, headers) {
  const results = [];
  for (const payload of PAYLOADS) {
    await sleep(300);
    try {
      let response;
      if (method === "GET") {
        const url = new URL(baseUrl);
        url.searchParams.set(paramName, payload);
        response = await fetch(url.toString(), { headers, signal: AbortSignal.timeout(8000) });
      } else {
        const body = new URLSearchParams({ [paramName]: payload });
        response = await fetch(baseUrl, { method: "POST", headers: { ...headers, "Content-Type": "application/x-www-form-urlencoded" }, body: body.toString(), signal: AbortSignal.timeout(8000) });
      }
      const text = (await response.text()).toLowerCase();
      const matched = SQL_ERROR_SIGNATURES.find(sig => text.includes(sig));
      if (matched) {
        results.push({ payload, evidence: text.substring(0, 500), severity: "critical", reason: matched });
      } else if (response.status >= 500) {
        results.push({ payload, evidence: `HTTP ${response.status}`, severity: "high", reason: "server_error" });
      }
    } catch (e) { /* timeout or network error, skip */ }
  }
  return results;
}

module.exports = async function runSqlInjection(scanId, nodes, scanConfig, db) {
  const findings = [];
  for (const node of nodes) {
    if (!node.url) continue;
    let params = [];
    try {
      const u = new URL(node.url);
      params = [...u.searchParams.entries()].filter(([k]) => !SKIP_PARAMS.has(k.toLowerCase()));
    } catch { continue; }
    if (params.length === 0) continue;

    const headers = {};
    if (scanConfig?.authConfig?.type === "jwt" && scanConfig.authConfig.token) {
      headers["Authorization"] = `Bearer ${scanConfig.authConfig.token}`;
    }

    for (const [paramName] of params) {
      const hits = await testParam(node.url, paramName, node.method || "GET", headers);
      for (const hit of hits) {
        const finding = {
          scanId,
          title: "SQL Injection",
          type: "sqli",
          severity: hit.severity,
          url: node.url,
          method: node.method || "GET",
          parameter: paramName,
          payload: hit.payload,
          evidence: hit.evidence,
          description: `SQL injection vulnerability detected in parameter "${paramName}". The application returned a database error when a crafted SQL payload was injected.`,
          aiExplanation: "",
          aiRemediation: "",
          businessImpact: "",
          cvssScore: hit.severity === "critical" ? 9.8 : 7.5,
          businessRiskScore: 0,
          falsePositiveConfidence: 0.05,
          isConfirmed: true,
          createdAt: new Date().toISOString()
        };
        findings.push(finding);
        await db.saveFinding(finding);
      }
    }
  }
  return findings;
};
```

