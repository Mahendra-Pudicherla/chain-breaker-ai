## RULE 11 — PDF Export on Report Page

FILE: frontend/src/pages/Report.tsx

Add a working "Download PDF" button using jsPDF + html2canvas:

```typescript
import jsPDF from 'jspdf';
import html2canvas from 'html2canvas';

const handleDownloadPdf = async () => {
  const reportElement = document.getElementById('report-content');
  if (!reportElement) return;

  // Show loading toast
  toast({ title: "Generating PDF...", description: "Please wait", variant: "default" });

  try {
    const canvas = await html2canvas(reportElement, {
      scale: 2,
      useCORS: true,
      backgroundColor: '#0a0a0f',
      logging: false,
    });

    const imgData = canvas.toDataURL('image/png');
    const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const pageWidth = pdf.internal.pageSize.getWidth();
    const pageHeight = pdf.internal.pageSize.getHeight();
    const imgWidth = pageWidth;
    const imgHeight = (canvas.height * imgWidth) / canvas.width;
    let heightLeft = imgHeight;
    let position = 0;

    pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
    heightLeft -= pageHeight;

    while (heightLeft > 0) {
      position = heightLeft - imgHeight;
      pdf.addPage();
      pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
      heightLeft -= pageHeight;
    }

    const fileName = `origin-report-${scan?.targetUrl?.replace(/[^a-z0-9]/gi, '-')}-${new Date().toISOString().split('T')[0]}.pdf`;
    pdf.save(fileName);
    toast({ title: "PDF Downloaded", description: fileName, variant: "default" });
  } catch (error) {
    toast({ title: "PDF Export Failed", description: "Try again or use browser print", variant: "destructive" });
  }
};
```

Install if not already present:
```bash
npm install jspdf html2canvas
```

Wrap the main report content in:
```tsx
<div id="report-content">
  {/* all report sections */}
</div>
```

