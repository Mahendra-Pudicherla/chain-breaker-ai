arules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /scans/{scanId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /findings/{findingId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/scans/$(scanId)).data.userId == request.auth.uid;
      }

      match /sitemapNodes/{nodeId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/scans/$(scanId)).data.userId == request.auth.uid;
      }
    }
  }
}
